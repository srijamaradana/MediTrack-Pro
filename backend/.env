# Server Configuration
PORT=5000
NODE_ENV=production
API_VERSION=v1

# Database
MONGODB_URI=mongodb+srv://yourusername:yourpassword@cluster.mongodb.net/meditrack_pro
MONGODB_URI_LOCAL=mongodb://localhost:27017/meditrack_pro

# JWT Security
JWT_SECRET=meditrack_pro_super_secret_key_2026_change_this
JWT_REFRESH_SECRET=meditrack_pro_refresh_secret_2026_change_this
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Cloudinary (Medical Reports Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (Gmail)
EMAIL_USER=meditrack@yourdomain.com
EMAIL_PASS=your_app_password
EMAIL_SERVICE=gmail

# Frontend
FRONTEND_URL=https://meditrack-pro.vercel.app
FRONTEND_URL_DEV=http://localhost:3000

# Security
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
MAX_FILE_SIZE=10485760

# Redis (For Production Caching)
REDIS_URL=redis://localhost:6379

# Twilio (For SMS Notifications)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890