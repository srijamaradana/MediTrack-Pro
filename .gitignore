cat > .gitignore << 'EOF'
# Environment Variables (NEVER commit these!)
.env
.env.*
*.env
backend/.env
frontend/.env

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
out/
.next/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/

# Temporary files
tmp/
temp/

# Uploads
uploads/
public/uploads/
EOF